Options -Indexes -MultiViews

# Force PHP 8.2 handler (StackCP/cPanel)
AddHandler application/x-httpd-php82 .php

# Prefer website homepage over API front controller.
DirectoryIndex index.html index.php

RewriteEngine On

# Prevent rewrite recursion on the front controller.
RewriteRule ^index\.php$ - [END]

# Block direct access to sensitive files.
RewriteRule ^\.env$ - [F,END]
RewriteRule ^bootstrap\.php$ - [F,END]
RewriteRule ^composer\.(json|lock)$ - [F,END]
RewriteRule ^logs/ - [F,END]

# If the target is an existing file/folder, do not rewrite.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [END]

# Route to API front controller only when explicit action is provided.
RewriteCond %{QUERY_STRING} (^|&)action= [NC]
RewriteRule ^ index.php [QSA,END]

# For other unmatched requests, show a normal 404 instead of API JSON error.
RewriteRule ^ - [END]
